{
  "name": "kawan-nusa-be",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build --minify --outfile dist/index.js --target bun src/index.ts",
    "start": "bun run src/index.ts",
    "seed": "bun run src/database/seed.ts",
    "sync-users": "bun run src/jobs/sync-users.job.ts",
    "sync-customers": "bun run src/jobs/sync-customers.job.ts",
    "sync": "bun run sync-users && bun run sync-customers",
    "sync-employees": "bun run src/jobs/sync-employees.job.ts",
    "sync-sheets:all": "bun run src/jobs/sync-point-sheet.job.ts --all",
    "sync-sheets": "bun run src/jobs/sync-point-sheet.job.ts --current",
    "expire-points": "bun run src/jobs/expire-points.job.ts"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-validator": "^0.7.6",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "google-auth-library": "^10.7.0",
    "google-spreadsheet": "^5.3.0",
    "hono": "^4.12.8",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.3",
    "pdfkit": "^0.18.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5"
  }
}